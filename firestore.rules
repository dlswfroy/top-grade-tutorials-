/**
 * This ruleset enforces a strict Role-Based Access Control (RBAC) model for the Top Grade Tutorials management application.
 *
 * Core Philosophy:
 * The security model is built around two primary roles: 'Admin' and 'Teacher'.
 * - Admins have comprehensive read and write permissions across all data, including managing user roles.
 * - Teachers have broad read access to institutional data (students, teachers) but can only create or modify records they are directly associated with (e.g., payments they collected, question papers they generated).
 * - All operations require user authentication; there is no public or anonymous access to data.
 *
 * Data Structure:
 * The data is organized into flat, top-level collections for each major entity (e.g., /students, /teachers, /payments). This structural segregation ensures that rules for one collection do not inadvertently affect another. Roles are not stored on a user document but are managed via dedicated collections (/roles_admin, /roles_teacher), a pattern known as Database-Backed Access Control (DBAC).
 *
 * Key Security Decisions:
 * - Default Deny: All paths are closed by default. Access is only granted through explicit `allow` statements.
 * - Role-Based Authorization: A user's role is determined by the existence of a document in `/roles_admin/{uid}` or `/roles_teacher/{uid}`. This is a highly performant and secure method for managing permissions.
 * - No User Listing: To prevent enumeration of privileged users, access to the role collections themselves is restricted to Admins.
 * - Restricted Writes: All write operations are protected. Teachers can only write documents they "own" by setting a specific ownership field (e.g., `teacherId`), while Admins have global write privileges.
 *
 * Denormalization for Authorization:
 * To create simpler and more performant rules, documents like `payments` and `question_papers` contain denormalized ownership fields (`teacherId` and `generatedByTeacherId`, respectively). This allows rules to authorize write operations with a simple check on the document's data (`resource.data.teacherId == request.auth.uid`) without needing slow and costly `get()` calls to other collections.
 *
 * Structural Segregation:
 * Each data type (students, teachers, roles) is stored in its own top-level collection. This separation is clean, scalable, and makes security rules easier to write and reason about, as all documents within a given path share the same security profile.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for Reusable Logic

    /**
     * Verifies that the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user has the 'Admin' role.
     * Role is granted if a document with their UID exists in the /roles_admin collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Checks if the authenticated user has the 'Teacher' role.
     * Role is granted if a document with their UID exists in the /roles_teacher collection.
     */
    function isTeacher() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }

    /**
     * Checks if the user is either an Admin or a Teacher.
     * Used for granting general read access to institutional data.
     */
    function isStaff() {
      return isAdmin() || isTeacher();
    }

    /**
     * Checks if the authenticated user's UID matches the provided ownerId.
     * This is used to verify ownership of a specific document.
     */
    function isOwner(ownerId) {
      return request.auth.uid == ownerId;
    }

    /**
     * Verifies that a document exists before an update or delete operation.
     * Prevents writes to non-existent paths.
     */
    function isExistingDocument() {
      return resource != null;
    }

    /**
     * On create, ensures the user is setting their own UID in an ownership field.
     * This forces relational integrity from the client.
     */
    function isCreatingAsSelf(ownerIdField) {
      return request.resource.data[ownerIdField] == request.auth.uid;
    }

    /**
     * On update, ensures a critical relational field (like an ownerId) is not changed.
     */
    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    /**
     * @description Rules for the 'students' collection.
     * @path /students/{studentId}
     * @allow (get) An authenticated teacher gets a specific student's record.
     * @allow (create) An admin creates a new student record.
     * @deny (update) A teacher attempts to modify a student's monthly fee.
     * @principle Restricts data management to admins, while allowing read-access for all staff.
     */
    match /students/{studentId} {
      allow get, list: if isStaff();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExistingDocument();
    }

    /**
     * @description Rules for the 'teachers' collection.
     * @path /teachers/{teacherId}
     * @allow (get) An authenticated teacher views another teacher's profile.
     * @allow (create) An admin adds a new teacher to the system.
     * @deny (delete) A teacher attempts to delete their own record.
     * @principle Restricts data management to admins, while allowing read-access for all staff.
     */
    match /teachers/{teacherId} {
      allow get, list: if isStaff();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExistingDocument();
    }

    /**
     * @description Rules for the 'payments' collection.
     * @path /payments/{paymentId}
     * @allow (create) A teacher creates a payment record, correctly setting their own `teacherId`.
     * @allow (update) The same teacher updates the payment details.
     * @deny (create) A teacher creates a payment record but assigns it to another teacher.
     * @deny (delete) A teacher tries to delete a payment record collected by another teacher.
     * @principle Enforces document ownership for writes. Teachers can only manage payments they collected.
     */
    match /payments/{paymentId} {
      allow get: if isAdmin() || (isTeacher() && isOwner(resource.data.teacherId));
      allow list: if isStaff();
      allow create: if isAdmin() || (isTeacher() && isCreatingAsSelf('teacherId'));
      allow update: if (isAdmin() && isExistingDocument()) || (isTeacher() && isExistingDocument() && isOwner(resource.data.teacherId) && isImmutable('teacherId'));
      allow delete: if (isAdmin() && isExistingDocument()) || (isTeacher() && isExistingDocument() && isOwner(resource.data.teacherId));
    }

    /**
     * @description Rules for the 'question_papers' collection.
     * @path /question_papers/{paperId}
     * @allow (create) A teacher generates a question paper, setting their own `generatedByTeacherId`.
     * @allow (get) An admin views a question paper generated by any teacher.
     * @deny (update) A teacher attempts to change the `generatedByTeacherId` on an existing paper.
     * @deny (delete) A teacher tries to delete a paper generated by someone else.
     * @principle Enforces document ownership for writes. Teachers can only manage papers they generated.
     */
    match /question_papers/{paperId} {
      allow get: if isAdmin() || (isTeacher() && isOwner(resource.data.generatedByTeacherId));
      allow list: if isStaff();
      allow create: if isAdmin() || (isTeacher() && isCreatingAsSelf('generatedByTeacherId'));
      allow update: if (isAdmin() && isExistingDocument()) || (isTeacher() && isExistingDocument() && isOwner(resource.data.generatedByTeacherId) && isImmutable('generatedByTeacherId'));
      allow delete: if (isAdmin() && isExistingDocument()) || (isTeacher() && isExistingDocument() && isOwner(resource.data.generatedByTeacherId));
    }

    /**
     * @description Rules for the singleton 'institution_settings' document.
     * @path /institution_settings/{settingsId}
     * @allow (get) An authenticated teacher reads the institution's name and logo URL.
     * @allow (update) An admin updates the institution's logo URL.
     * @deny (create) A teacher attempts to create a new settings document.
     * @principle Restricts modification of global settings to admins only.
     */
    match /institution_settings/{settingsId} {
      allow get, list: if isStaff();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExistingDocument();
    }

    /**
     * @description Rules for the 'roles_admin' collection, which grants Admin privileges.
     * @path /roles_admin/{adminUid}
     * @allow (create) An existing admin grants admin privileges to another user.
     * @deny (get) A teacher tries to list all the admins in the system.
     * @deny (delete) A non-admin user attempts to remove an admin role.
     * @principle Protects role-granting collections by restricting all access to existing admins.
     */
    match /roles_admin/{adminUid} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExistingDocument();
    }

    /**
     * @description Rules for the 'roles_teacher' collection, which grants Teacher privileges.
     * @path /roles_teacher/{teacherUid}
     * @allow (create) An admin grants teacher privileges to a user.
     * @deny (list) A teacher tries to see who all the other teachers are by reading this collection.
     * @deny (update) A teacher tries to modify their own role document.
     * @principle Protects role-granting collections by restricting all access to existing admins.
     */
    match /roles_teacher/{teacherUid} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && isExistingDocument();
    }

  }
}