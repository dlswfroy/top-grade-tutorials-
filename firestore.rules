
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isHeadTeacher() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isTeacher() {
       return exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }

    match /students/{studentId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /teachers/{teacherId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /payments/{paymentId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /question_papers/{paperId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /institution_settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isHeadTeacher();
    }

    match /roles_admin/{adminUid} {
      // Allow any signed-in user to check for existence of an admin role (for isHeadTeacher() to work).
      allow get: if isSignedIn();
      // Allow any signed-in user to check if at least one admin exists (for first-user-is-admin logic).
      allow list: if isSignedIn() && request.query.limit <= 1;
      // Allow head teachers to manage roles.
      allow write: if isHeadTeacher();
    }

    match /roles_teacher/{teacherUid} {
       // Allow any signed-in user to check for existence of a teacher role (for isTeacher() to work).
       allow get: if isSignedIn();
       // Allow head teachers to manage roles.
       allow list, write: if isHeadTeacher();
    }
    
    match /teacher_permissions/{teacherId} {
      // A teacher can read their own permissions. A head teacher can read any.
      allow get: if isHeadTeacher() || (isTeacher() && request.auth.uid == teacherId);
      // Only a head teacher can modify permissions.
      allow list, write: if isHeadTeacher();
    }

    match /expenses/{expenseId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /attendance/{attendanceId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }
  }
}
