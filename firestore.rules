
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if a user is authenticated.
    function isSignedIn() {
      return request.auth != null;
    }

    // This is a permissive rule for initial development and prototyping.
    // It allows any authenticated user (including anonymous users) to read and write to the entire database.
    // For a production application, you should implement more granular security rules.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
