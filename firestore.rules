
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are completely open and do not provide any security.
    // Any user can read, write, and delete any data in your database.
    // This is not recommended for production applications.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

    