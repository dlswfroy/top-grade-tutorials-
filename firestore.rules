
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isHeadTeacher() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isTeacher() {
       return exists(/databases/$(database)/documents/roles_teacher/$(request.auth.uid));
    }

    match /students/{studentId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /teachers/{teacherId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /payments/{paymentId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /question_papers/{paperId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /institution_settings/{settingsId} {
      allow read: if isHeadTeacher() || isTeacher();
      allow write: if isHeadTeacher();
    }

    match /roles_admin/{adminUid} {
      allow read, write: if isHeadTeacher();
    }

    match /roles_teacher/{teacherUid} {
       allow read, write: if isHeadTeacher();
    }
    
    match /teacher_permissions/{teacherId} {
      allow read: if isHeadTeacher() || (isTeacher() && request.auth.uid == teacherId);
      allow write: if isHeadTeacher();
    }

    match /expenses/{expenseId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }

    match /attendance/{attendanceId} {
      allow read, write: if isHeadTeacher() || isTeacher();
    }
  }
}
