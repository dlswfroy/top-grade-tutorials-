
{
  "entities": {
    "Student": {
      "title": "Student",
      "type": "object",
      "description": "Represents a student enrolled in Top Grade Tutorials.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "classGrade": { "type": "string", "enum": ["ষষ্ঠ", "সপ্তম", "অষ্টম", "নবম", "দশম"] },
        "rollNumber": { "type": "string" },
        "fatherName": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "monthlyFee": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "dateAdded": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "classGrade", "rollNumber", "fatherName", "mobileNumber", "monthlyFee", "dateAdded"]
    },
    "Teacher": {
      "title": "Teacher",
      "type": "object",
      "description": "Represents a teacher at the institution.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "imageUrl": { "type": "string", "format": "uri" },
        "dateAdded": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subject", "mobileNumber", "dateAdded"]
    },
    "Payment": {
      "title": "Payment",
      "type": "object",
      "description": "Records a payment made by a student.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "collectorName": { "type": "string" },
        "amount": { "type": "number" },
        "paymentDate": { "type": "string", "format": "date-time" },
        "paymentMonth": { "type": "string" },
        "receiptNumber": { "type": "string" }
      },
      "required": ["studentId", "collectorName", "amount", "paymentDate", "paymentMonth", "receiptNumber"]
    },
    "Expense": {
      "title": "Expense",
      "type": "object",
      "description": "Records an expense made by the institution.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "expenseDate": { "type": "string", "format": "date-time" },
        "spentByName": { "type": "string" }
      },
      "required": ["description", "amount", "expenseDate", "spentByName"]
    },
    "Attendance": {
        "title": "Attendance",
        "type": "object",
        "description": "Records student attendance for a specific date.",
        "properties": {
            "id": { "type": "string" },
            "studentId": { "type": "string" },
            "classGrade": { "type": "string", "enum": ["ষষ্ঠ", "সপ্তম", "অষ্টম", "নবম", "দশম"] },
            "date": { "type": "string", "format": "date" },
            "status": { "type": "string", "enum": ["present", "absent"] }
        },
        "required": ["studentId", "classGrade", "date", "status"]
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "Log of messages or calls sent to students/parents.",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "type": { "type": "string", "enum": ["sms", "call"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["studentId", "type", "timestamp"]
    },
    "UserRole": {
        "title": "UserRole",
        "type": "object",
        "description": "Defines the role of a user in the system.",
        "properties": {
            "id": { "type": "string" },
            "email": { "type": "string", "format": "email"},
            "name": { "type": "string" },
            "role": { "type": "string", "enum": ["admin", "teacher"] },
            "imageUrl": { "type": "string", "format": "uri" },
            "permissions": {
              "type": "object",
              "description": "Granular access control for different app sections."
            }
        },
        "required": ["email", "name", "role"]
    },
    "InstitutionSettings": {
        "title": "InstitutionSettings",
        "type": "object",
        "description": "Stores global settings for the institution.",
        "properties": {
            "id": { "type": "string" },
            "institutionName": { "type": "string" },
            "logoUrl": { "type": "string", "format": "uri" },
            "lastUpdated": { "type": "string", "format": "date-time" }
        },
        "required": ["institutionName", "lastUpdated"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "collections": {
      "students": {
        "schema": { "$ref": "#/entities/Student" },
        "description": "Contains records of all enrolled students."
      },
      "teachers": {
        "schema": { "$ref": "#/entities/Teacher" },
        "description": "Contains records of all teachers."
      },
      "payments": {
        "schema": { "$ref": "#/entities/Payment" },
        "description": "Records all student fee payments."
      },
      "expenses": {
        "schema": { "$ref": "#/entities/Expense" },
        "description": "Records all institutional expenses."
      },
      "attendance": {
        "schema": { "$ref": "#/entities/Attendance" },
        "description": "Contains daily student attendance records."
      },
      "messages": {
        "schema": { "$ref": "#/entities/Message" },
        "description": "History of communications with parents."
      },
      "user_roles": {
          "schema": { "$ref": "#/entities/UserRole" },
          "description": "Stores the role for each user."
      },
      "institution_settings": {
        "schema": { "$ref": "#/entities/InstitutionSettings" },
        "description": "Stores global institution settings as a singleton document."
      }
    }
  }
}
